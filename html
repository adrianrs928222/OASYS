<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Chiringuito Oasis | 5 Estrellas</title>

<link rel="stylesheet" href="assets/css/style.css">
<link rel="icon" href="assets/img/favicon.png">

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">
</head>

<body>

<!-- HEADER -->
<header class="header">
  <div class="container header-inner">

    <div class="logo">
      <img src="assets/img/logo.png" alt="Logo">
    </div>

    <nav class="nav">
      <a href="#inicio">Inicio</a>
      <a href="#carta">Carta</a>
      <a href="#ubicacion">Ubicación</a>
      <a href="#contacto">Contacto</a>
    </nav>

    <div class="social">
      <a href="https://www.facebook.com/share/18Li5ewPVT/" target="_blank">
        <img src="assets/img/facebook.png">
      </a>

      <a href="https://www.instagram.com/chiringuitooasischipiona?igsh=MWo1eGo2cHV0bmo5bw==" target="_blank">
        <img src="assets/img/instagram.png">
      </a>
    </div>

  </div>
</header>

<!-- HERO -->
<section id="inicio" class="hero">
  <div class="overlay"></div>

  <div class="hero-content">
    <h1>Chiringuito Oasis</h1>
    <p>Beach Club · Gastronomía Mediterránea · Experiencia 5⭐</p>

    <a href="#carta" class="btn">Ver Carta</a>
  </div>
</section>

<!-- CARTA -->
<section id="carta" class="section">
  <div class="container">

    <h2 class="title">Nuestra Carta</h2>
    <p class="subtitle">Cocina mediterránea frente al mar</p>

    <div class="card-glass">
      <img src="assets/img/carta.jpg" id="cartaImg" alt="Carta">
    </div>

  </div>
</section>

<!-- UBICACIÓN -->
<section id="ubicacion" class="section dark">
  <div class="container">

    <h2 class="title">Ubicación</h2>
    <p>📍 Playa Cruz del Mar, 11550 Chipiona, Cádiz</p>

    <div class="map-container">
      <iframe
        src="https://www.google.com/maps?q=Playa%20Cruz%20del%20Mar%2C%2011550%20Chipiona%2C%20C%C3%A1diz&output=embed"
        width="100%"
        height="350"
        style="border:0; border-radius:12px;"
        loading="lazy">
      </iframe>
    </div>

  </div>
</section>

<!-- CONTACTO -->
<section id="contacto" class="section dark">
  <div class="container">

    <h2 class="title">Contacto</h2>

    <p>📞 +34 606 93 28 42</p>

    <a class="btn-whatsapp"
       href="https://wa.me/34606932842?text=Hola%20quiero%20reservar%20en%20Chiringuito%20Oasis"
       target="_blank">
       Reservar por WhatsApp
    </a>

  </div>
</section>

<!-- MODAL CARTA -->
<div id="modal" class="modal">
  <span class="close">&times;</span>
  <img class="modal-content" id="imgModal">
</div>

<!-- FOOTER -->
<footer class="footer">
  <p>© 2026 Chiringuito Oasis · Beach Club 5⭐</p>
</footer>

<script src="assets/js/main.js"></script>

</body>
</html>
